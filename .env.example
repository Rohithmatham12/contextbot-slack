# Slack — get from api.slack.com/apps
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token

# Groq — free at console.groq.com
GROQ_API_KEY=gsk_your-groq-key

# Path to the repo ContextOS will scan
# For local dev: absolute path to any repo on your machine
# For Render: /opt/render/project/src (the cloned demo repo)
REPO_PATH=/path/to/your/repo

# Optional: path to contextos binary if not in PATH
# CONTEXTOS_BIN=/home/user/.local/bin/contextos
